# Celo RPC endpoints
NEXT_PUBLIC_CELO_RPC=https://forno.celo.org
NEXT_PUBLIC_ALFAJORES_RPC=https://alfajores-forno.celo-testnet.org

# Active chain: "celo" (mainnet) or "alfajores" (staging)
NEXT_PUBLIC_CHAIN=alfajores

# Deployed QuincyBounty contract addresses (per network)
NEXT_PUBLIC_QUINCY_ADDRESS_CELO=0x9af5fbb05054a4d072def7bb73978c48dfe6d3d5
NEXT_PUBLIC_QUINCY_ADDRESS_ALFAJORES=0x0000000000000000000000000000000000000000

# Read API base (indexer-backed)
NEXT_PUBLIC_API_BASE=/api/v1

# web3.storage token for IPFS proof uploads (client-side)
NEXT_PUBLIC_W3S_TOKEN=

# Pinata JWT for server-side IPFS proof uploads (/api/upload). If unset, file
# upload is disabled and hunters paste a link/CID instead.
PINATA_JWT=
